# Copy to .env and adjust as needed.

# PostgreSQL connection (matches docker-compose.yml defaults).
DATABASE_URL=postgres://sr_user:sr_password@localhost:5432/sr_pipeline

# Rust backend
BIND_ADDR=0.0.0.0:8080
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs/jobs
FRONTEND_DIR=frontend

# Backend URL used by the Python worker / benchmark POSTs
BACKEND_URL=http://localhost:8080
