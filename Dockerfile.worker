# CPU inference worker — builds natively on amd64 and arm64 (Oracle Ampere).
FROM python:3.12-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install torch from PyPI so the correct arch wheel is picked (x86_64 or aarch64).
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu \
    || pip install --no-cache-dir torch \
    && pip install --no-cache-dir \
        opencv-python-headless \
        numpy \
        scikit-image \
        onnx \
        onnxscript \
        onnxruntime \
        requests

COPY models ./models
COPY utils ./utils
COPY ml ./ml
COPY weights ./weights

ENV BACKEND_URL=http://backend:8080
ENV OUTPUT_DIR=/data/outputs
# Keep CPU/RAM usage low on Always Free Micro (1 GB).
ENV OMP_NUM_THREADS=1
ENV MKL_NUM_THREADS=1
ENV TORCH_NUM_THREADS=1

CMD ["python", "-m", "ml.worker", \
     "--WEIGHTS_PATH", "weights/demo_c96b16.pth", \
     "--CHANNELS", "96", \
     "--NUM_BLOCKS", "16", \
     "--BACKEND_URL", "http://backend:8080", \
     "--OUTPUT_DIR", "/data/outputs", \
     "--TILE", "128", \
     "--OVERLAP", "16", \
     "--MAX_INPUT_HEIGHT", "320"]
